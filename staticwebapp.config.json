{
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/9a73d9e7-7a7b-4c5e-840f-766d04d5421f/v2.0",
          "clientIdSettingName": "AAD_CLIENT_ID",
          "clientSecretSettingName": "AAD_CLIENT_SECRET"
        }
      }
    }
  },
  "routes": [
    { "route": "/splitter", "rewrite": "/splitter/index.html", "allowedRoles": ["authenticated"] },
    { "route": "/toolkit", "rewrite": "/toolkit/index.html", "allowedRoles": ["authenticated"] },
    { "route": "/api/*", "allowedRoles": ["authenticated"] },
    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/splitter/*", "/splitter/index.html", "/toolkit/*", "/toolkit/index.html"]
  }
}
